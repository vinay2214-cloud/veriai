# VeriAI Hackathon Configuration
# Minimal required for Render.com free tier

# Storage
DATASETS_DIR=data/datasets
MAX_FILE_SIZE_MB=10

# Demo access
DEMO_API_KEY=veriai-demo-2026

# Google Cloud (for Gemini RAG truth verification)
GEMINI_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1

# CORS (leave empty to allow all origins during hackathon)
ALLOWED_ORIGINS=*

# Future security (not active in hackathon version):
# VERIAI_MASTER_KEY=   # AES-256-GCM encryption key
# JWT_SECRET=          # JWT signing key
# DB_ENCRYPTION_KEY=   # SQLite field encryption
