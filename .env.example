# VeriAI environment example
# Copy to .env for local development, or configure these in Render.

# Security secrets
# Generate with: python scripts/generate_secrets.py
VERIAI_MASTER_KEY=
JWT_SECRET=
DB_ENCRYPTION_KEY=

# Deployment / CORS
ALLOWED_ORIGINS=https://veriai-eyxl.onrender.com,http://localhost:8000,http://127.0.0.1:8000
VERIAI_CORS_ORIGINS=https://veriai-eyxl.onrender.com,http://localhost:8000,http://127.0.0.1:8000
DEMO_MODE=true

# Storage-light demo limits
VERIAI_DB_PATH=/var/data/veriai.db
DATASETS_DIR=/var/data/datasets
RETENTION_DAYS=7
MAX_FILE_SIZE_MB=5
MAX_PUBLIC_UPLOAD_MB=5
MAX_PUBLIC_UPLOAD_ROWS=5000
MAX_AUDIT_RECORDS=75
MAX_REVIEW_RECORDS=100
MAX_FEEDBACK_RECORDS=200
MAX_KB_ARTICLES=75
MAX_REPORT_JSON_CHARS=18000

# Optional LLM / embedding keys
GEMINI_API_KEY=
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
OPENAI_API_KEY=

# Logging
VERIAI_LOG_LEVEL=INFO
